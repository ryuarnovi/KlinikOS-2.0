# ============================================================
# KLINIKOS FRONTEND — .dockerignore
# Digunakan oleh Docker saat build context untuk folder frontend/
# ============================================================

.DS_Store
.env
.env.local
.env.*.local

# Dependencies (Docker menginstall sendiri dari package.json)
node_modules/

# Next.js build output
.next/
out/
build/
.cache/
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
